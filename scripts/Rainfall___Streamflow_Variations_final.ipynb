import pandas as pd
import matplotlib.pyplot as plt
import matplotlib.dates as mdates
from matplotlib import rcParams
import numpy as np
import os
from pathlib import Path
from scipy.stats import linregress
from matplotlib.patches import Patch
import seaborn as sns

output_dir = r"D:\Research Datasets\Additional Datasets\Working Folder\Rainfall Variations\Plots"
os.makedirs(output_dir, exist_ok=True)

rf_stations = [
    {"name": "Deraniyagala", "file": r"D:\...\Deraniyagala_RF_1990-2015.xlsx"},
    {"name": "Nawalapitiya", "file": r"D:\...\Nawalapitiya_RF_1990-2015.xlsx"},
    {"name": "Wellawaya",    "file": r"D:\...\Welawaya_RF_1990_2015.xlsx"},
    {"name": "Padiyathalawa","file": r"D:\...\Padiyathalawa_Welipitiya_RF_1990_2015.xlsx"}
]

sf_stations = [
    {"name": "Deraniyagala", "file": r"D:\...\Deraniyagala_SF_1990-2015.xlsx"},
    {"name": "Nawalapitiya", "file": r"D:\...\Nawalapitiya_SF_1990-2015.xlsx"},
    {"name": "Wellawaya",    "file": r"D:\...\Welawaya_SF_1990_2015.xlsx"},
    {"name": "Padiyathalawa","file": r"D:\...\Padiyathalawa_SF_1990_2015.xlsx"}
]

month_labels = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec']
colors = ['blue', 'darkblue', 'orange', 'red']

# =============================================================================
# 1. MONTHLY STREAMFLOW HYDROGRAPHS WITH ±1 STD BAND (2x2, all stations)
# =============================================================================
rcParams['font.family'] = 'Times New Roman'
rcParams['font.size'] = 14
rcParams['axes.titlesize'] = 16
rcParams['axes.labelsize'] = 14
rcParams['xtick.labelsize'] = 12
rcParams['ytick.labelsize'] = 12
rcParams['legend.fontsize'] = 12

data_list = []
for station in sf_stations:
    path = Path(station["file"])
    if not path.exists():
        raise FileNotFoundError(f"File not found: {path}")

    df = pd.read_excel(path, parse_dates=['Date'])
    df = df[['Date', 'Discharge']].dropna()
    df = df[(df['Date'].dt.year >= 1990) & (df['Date'].dt.year <= 2015)]
    df['Month'] = df['Date'].dt.strftime('%b')
    df['Month_num'] = df['Date'].dt.month

    monthly = df.groupby('Month_num').agg(
        mean=('Discharge', 'mean'),
        std=('Discharge', 'std'),
        count=('Discharge', 'count')
    ).reset_index()
    monthly['Month_name'] = pd.date_range('1990-01-01', periods=12, freq='MS').strftime('%b')
    monthly = monthly.sort_values('Month_num')
    monthly['upper'] = monthly['mean'] + monthly['std']
    monthly['lower'] = monthly['mean'] - monthly['std']

    data_list.append({'name': station["name"], 'monthly': monthly})

fig = plt.figure(figsize=(12, 8))
gs = fig.add_gridspec(2, 2, hspace=0.35, wspace=0.35)

for i, item in enumerate(data_list):
    ax = fig.add_subplot(gs[i // 2, i % 2])
    dfm = item['monthly']
    name = item['name']

    ymax = dfm['upper'].max() * 1.12
    ymax = np.ceil(ymax / 80) * 80

    ax.fill_between(range(1, 13), dfm['lower'], dfm['upper'], color='#92d1d4', alpha=0.8, label='Mean ±1 STD')
    ax.plot(range(1, 13), dfm['mean'], color='black', linewidth=2.2, label='Mean')

    ax.set_ylim(0, ymax)
    ax.set_xlim(0.5, 12.5)
    ax.set_xticks(range(1, 13))
    ax.set_xticklabels(month_labels)
    ax.set_ylabel('Streamflow (m³/s)')
    ax.set_title(f'({chr(97 + i)}) {name}')
    ax.grid(True, which='major', axis='both', linestyle='-', alpha=0.5)
    ax.legend(loc='upper right', frameon=True, fancybox=False, edgecolor='black', fontsize=10)

plt.savefig('average_streamflow_hydrographs_with_legend.png', dpi=300, bbox_inches='tight')
plt.show()

# =============================================================================
# 2. ANNUAL RAINFALL (ERROR BARS) + MONTHLY RAINFALL DISTRIBUTION (jittered box)
# =============================================================================
fig1, ax1 = plt.subplots(figsize=(8, 5))
width = 0.2

for i, st in enumerate(rf_stations):
    file = st["file"]
    if not os.path.exists(file):
        print(f"Missing: {file}")
        continue

    df = pd.read_excel(file, parse_dates=['Date'])
    df = df.set_index('Date').sort_index()

    annual = df['Rainfall'].resample('YE').sum()
    annual_std = df['Rainfall'].resample('YE').std()

    years = annual.index.year
    values = annual.values
    stds = annual_std.values

    offset = (i - 1.5) * width
    ax1.bar(years + offset, values, width=width, label=st["name"], color=colors[i],
            edgecolor='black', linewidth=0.8, alpha=0.7, yerr=stds, capsize=3,
            error_kw={'linewidth': 1.2, 'capthick': 1.2})

    slope, intercept, _, _, _ = linregress(years, values)
    trend = slope * years + intercept
    ax1.plot(years, trend, color=colors[i], linewidth=3, linestyle='--')

ax1.set_title('Annual Rainfall Variations of Wet & Dry zones (1990-2015)', fontsize=18, fontname='Times New Roman', pad=20)
ax1.set_ylabel('Rainfall (mm/year)', fontsize=16)
ax1.set_xlabel('Year', fontsize=16)
ax1.set_xticks(np.arange(1990, 2016, 4))
ax1.grid(True, axis='both', linestyle='-', alpha=0.6)
ax1.spines[['top', 'right']].set_visible(False)
ax1.legend(fontsize=10, prop={'family': 'Times New Roman'}, loc='upper left', frameon=False, ncol=2)
ax1.tick_params(labelsize=14)
ax1.text(0.02, 0.98, 'Error bars = ±1 SD of daily rainfall within each year',
         transform=ax1.transAxes, fontsize=9, verticalalignment='top',
         bbox=dict(boxstyle="round,pad=0.3", facecolor="white", alpha=0.8))

plt.tight_layout()
fig1.savefig(os.path.join(output_dir, "Annual_Rainfall_1990-2015b.png"), dpi=300, bbox_inches='tight')
plt.close(fig1)

fig2, ax2 = plt.subplots(figsize=(7, 4))
data_for_box = []
positions = []

for month in range(1, 13):
    for i, st in enumerate(rf_stations):
        file = st["file"]
        if not os.path.exists(file):
            continue
        df = pd.read_excel(file, parse_dates=['Date'])
        df['month'] = df['Date'].dt.month
        monthly_data = df[df['month'] == month]['Rainfall'].dropna().values
        if len(monthly_data) > 0:
            data_for_box.append(monthly_data)
            positions.append(month + (i - 1.5) * 0.15)

bp = ax2.boxplot(data_for_box, positions=positions, widths=0.12, patch_artist=True,
                  showfliers=False, medianprops={'color': 'black', 'linewidth': 2},
                  boxprops={'linewidth': 1.5}, whiskerprops={'linewidth': 1.2}, capprops={'linewidth': 1.2})

for i, box in enumerate(bp['boxes']):
    box.set_facecolor(colors[i % 4])
    box.set_alpha(0.6)

for pos, vals in zip(positions, data_for_box):
    jitter = np.random.uniform(-0.04, 0.04, size=len(vals))
    ax2.scatter(pos + jitter, vals, color='gray', alpha=0.4, s=10)

ax2.set_title('Monthly Rainfall Distribution of Wet & Dry zones (1990-2015)', fontsize=18, fontname='Times New Roman', pad=20)
ax2.set_xlabel('Month', fontsize=16)
ax2.set_ylabel('Rainfall (mm/month)', fontsize=16)
ax2.set_xticks(range(1, 13))
ax2.set_xticklabels(month_labels)
ax2.grid(True, axis='both', linestyle='-', alpha=0.6)
ax2.spines[['top', 'right']].set_visible(False)

legend_elements = [Patch(facecolor=colors[i], alpha=0.6, edgecolor='black', label=rf_stations[i]["name"]) for i in range(4)]
ax2.legend(handles=legend_elements, fontsize=6, prop={'family': 'Times New Roman'}, loc='upper right', frameon=False, ncol=2)
ax2.tick_params(labelsize=14)

plt.tight_layout()
fig2.savefig(os.path.join(output_dir, "Monthly_Rainfall_Distribution_1990-2015.png"), dpi=300, bbox_inches='tight')
plt.close(fig2)

# =============================================================================
# 3. SEASONAL RAINFALL BOXPLOTS — 2x2 (a)-(d) AND combined comparison
# =============================================================================
seasons = {
    'FIM (Mar-Apr)': (3, 4), 'SWM (May-Sep)': (5, 9),
    'SIM (Oct-Nov)': (10, 11), 'NEM (Dec-Feb)': (12, 2)
}
season_order = list(seasons.keys())

def get_season(m):
    for name, (s, e) in seasons.items():
        if s <= e:
            if s <= m <= e:
                return name
        else:
            if m >= s or m <= e:
                return name

plt.rcParams['font.family'] = 'Times New Roman'
plt.rcParams['font.size'] = 18

all_data = []
for station in rf_stations:
    df = pd.read_excel(station["file"])
    date_col, rain_col = df.columns[0], df.columns[1]
    df = df[[date_col, rain_col]].copy()
    df.columns = ['Date', 'Rainfall']
    df['Date'] = pd.to_datetime(df['Date'], errors='coerce')
    df = df.dropna(subset=['Date', 'Rainfall'])
    df['Year'] = df['Date'].dt.year
    df['Month'] = df['Date'].dt.month
    df['Season'] = df['Month'].apply(get_season)
    seasonal = df.groupby(['Year', 'Season'])['Rainfall'].sum().reset_index()
    seasonal['Station'] = station["name"]
    all_data.append(seasonal)

full_df = pd.concat(all_data, ignore_index=True)
full_df['Season'] = pd.Categorical(full_df['Season'], categories=season_order, ordered=True)

fig, axes = plt.subplots(2, 2, figsize=(14, 10))
axes = axes.flatten()
labels = ['(a)', '(b)', '(c)', '(d)']

for idx, (season_name, ax) in enumerate(zip(season_order, axes)):
    data = full_df[full_df['Season'] == season_name]
    sns.boxplot(data=data, x='Station', y='Rainfall', palette=colors, ax=ax, notch=True,
                showmeans=True, meanline=True, meanprops={'color': 'black', 'ls': '--', 'lw': 1.2},
                linewidth=1.8, fliersize=4)
    ax.grid(True, axis='both', ls='-', alpha=0.7)
    ax.set_title(f"{labels[idx]} {season_name}", fontsize=20, pad=20)
    ax.set_ylabel('Rainfall (mm)' if idx % 2 == 0 else '', fontsize=18)
    ax.set_xlabel('', fontsize=16)
    ax.tick_params(axis='both', labelsize=16)
    ax.set_ylim(0, None)

axes[-1].legend(title='', ncol=2, fontsize=10, title_fontsize=12)
plt.tight_layout(pad=3.5)
plt.savefig(os.path.join(output_dir, "SriLanka_Seasonal_Boxplots_2x2.png"), dpi=300, bbox_inches='tight')
plt.show()

plt.figure(figsize=(10, 6))
sns.boxplot(data=full_df, x='Season', y='Rainfall', hue='Station', palette=colors, notch=True,
            showmeans=True, meanline=True, meanprops={'color': 'black', 'ls': '--', 'lw': 1},
            linewidth=1.8, fliersize=4)
plt.grid(True, axis='both', ls='-', alpha=0.7)
plt.xlabel('Season', fontsize=18)
plt.ylabel('Seasonal Rainfall (mm)', fontsize=18)
plt.legend(title='', ncol=2, fontsize=16, title_fontsize=18)
plt.tick_params(axis='both', labelsize=18)
plt.tight_layout()
plt.savefig(os.path.join(output_dir, "SriLanka_Seasonal_Rainfall_Combined_Comparison.png"), dpi=300, bbox_inches='tight')
plt.show()

# =============================================================================
# 4. ANNUAL & MONTHLY RAINFALL — grouped bar, SEM error bars, trendlines
# =============================================================================
plt.rcParams['font.family'] = 'Times New Roman'
plt.rcParams['font.size'] = 18
colors2 = ['steelblue', 'blue', 'orange', 'red']

data = {}
for st in rf_stations:
    path = st["file"]
    if not os.path.exists(path):
        print(f"File not found: {path}")
        continue
    df = pd.read_excel(path, parse_dates=['Date'])
    data[st["name"]] = df.set_index('Date')['Rainfall'].sort_index()

active_names = [name for name in [s["name"] for s in rf_stations] if name in data]
n_stations = len(active_names)

# --- Plot 1: Annual ---
years = np.arange(1990, 2016)
width = 0.8 / n_stations
fig1, ax1 = plt.subplots(figsize=(10, 6.5))
for i, name in enumerate(active_names):
    annual = data[name].resample('YE').sum()
    values = annual.reindex(pd.date_range('1990-01-01', '2015-12-31', freq='YE')).values
    valid = ~np.isnan(values)

    ax1.bar(years + (i - (n_stations - 1) / 2) * width, values, width * 0.95,
            label=name, color=colors2[i], edgecolor='black', linewidth=0.7, alpha=0.85)

    if valid.sum() > 2:
        slope, intercept, _, _, _ = linregress(years[valid], values[valid])
        ax1.plot(years, slope * years + intercept, color=colors2[i], lw=2.5, ls='--')

ax1.set_title('Annual Rainfall Variations in Wet and Dry Zones (1990–2015)', fontsize=18, pad=20, fontweight='bold')
ax1.set_xlabel('Year', fontsize=18)
ax1.set_ylabel('Rainfall (mm/year)', fontsize=18)
ax1.set_xticks(years[::2])
ax1.grid(True, axis='both', linestyle='-', alpha=0.5)
ax1.spines[['top', 'right']].set_visible(False)
ax1.legend(frameon=False, fontsize=10, ncol=2)
ax1.tick_params(labelsize=16)
plt.tight_layout()
fig1.savefig(os.path.join(output_dir, "Annual_Rainfall_1990-2015.png"), dpi=400, bbox_inches='tight')
plt.show()

# --- Plot 2: Monthly with SEM error bars + trendlines ---
fig2, ax2 = plt.subplots(figsize=(10, 6.5))
months = np.arange(1, 13)
width = 0.8 / n_stations
for i, name in enumerate(active_names):
    monthly_df = data[name].resample('ME').sum().to_frame('Rainfall')
    monthly_df['month'] = monthly_df.index.month
    grouped = monthly_df.groupby('month')['Rainfall']
    means = grouped.mean().reindex(months).values
    stds = grouped.std().reindex(months).values
    counts = grouped.count().reindex(months).values
    sem = np.nan_to_num(stds / np.sqrt(counts), nan=0)

    ax2.bar(months + (i - (n_stations - 1) / 2) * width, means, width * 0.95, yerr=sem, capsize=4,
            label=name, color=colors2[i], edgecolor='black', linewidth=0.8, alpha=0.9)

    slope, intercept, _, _, _ = linregress(months, means)
    ax2.plot(months, slope * months + intercept, color=colors2[i], linestyle='--', linewidth=2.2)

ax2.set_title('Monthly Rainfall of Wet and Dry Zones (1990–2015)', fontsize=18, pad=20, fontweight='bold')
ax2.set_xlabel('Month', fontsize=18)
ax2.set_ylabel('Rainfall (mm/month)', fontsize=18)
ax2.set_xticks(months)
ax2.set_xticklabels(month_labels, fontsize=16)
ax2.grid(True, axis='both', alpha=0.6)
ax2.spines[['top', 'right']].set_visible(False)
ax2.legend(frameon=False, fontsize=11, ncol=2)
ax2.tick_params(labelsize=16)
plt.tight_layout()
fig2.savefig(os.path.join(output_dir, "Mean_Monthly_Rainfall_with_SEM_Trendlines_1990-2015.png"), dpi=400, bbox_inches='tight')
plt.show()

# --- Plot 3: Monthly grouped bar (0-filled, no error bars) ---
fig3, ax3 = plt.subplots(figsize=(12, 6))
for i, name in enumerate(active_names):
    monthly_df = data[name].resample('ME').sum().to_frame('Rainfall')
    monthly_df['month'] = monthly_df.index.month
    means = monthly_df.groupby('month')['Rainfall'].mean().reindex(months, fill_value=0).values

    ax3.bar(months + (i - (n_stations - 1) / 2) * width, means, width * 0.95,
            label=name, color=colors2[i], edgecolor='black', linewidth=0.8, alpha=0.9)

ax3.set_title("Mean Monthly Rainfall of Wet and Dry Zones (1990–2015)", fontsize=18, pad=20)
ax3.set_xlabel("Month", fontsize=18)
ax3.set_ylabel("Rainfall (mm/month)", fontsize=18)
ax3.set_xticks(months)
ax3.set_xticklabels(month_labels, fontsize=11)
ax3.grid(True, axis='both', alpha=0.5)
ax3.spines[['top', 'right']].set_visible(False)
ax3.legend(frameon=False, ncol=2, fontsize=10)
ax3.tick_params(labelsize=16)
plt.tight_layout()
fig3.savefig(os.path.join(output_dir, "Mean_Monthly_Rainfall_GroupedBar_1990-2015.png"), dpi=400, bbox_inches='tight')
plt.show()

# =============================================================================
# 5. MONTHLY MEAN STREAMFLOW — 2x2 line plots (fixed y-axis 0-30)
# =============================================================================
rcParams['font.family'] = 'Times New Roman'
rcParams['font.size'] = 12
rcParams['axes.titlesize'] = 14
rcParams['axes.labelsize'] = 10
rcParams['xtick.labelsize'] = 11
rcParams['ytick.labelsize'] = 11

data_list = []
for station in sf_stations:
    path = Path(station["file"])
    if not path.exists():
        raise FileNotFoundError(f"File not found: {path}")

    df = pd.read_excel(path, parse_dates=['Date'])
    df = df[['Date', 'Discharge']].dropna()
    df = df[(df['Date'].dt.year >= 1990) & (df['Date'].dt.year <= 2015)]
    df['Month_num'] = df['Date'].dt.month

    monthly_mean = df.groupby('Month_num')['Discharge'].mean().reset_index()
    monthly_mean = monthly_mean.set_index('Month_num').reindex(range(1, 13)).reset_index()

    data_list.append({'name': station["name"], 'monthly_mean': monthly_mean})

fig, axes = plt.subplots(2, 2, figsize=(7.5, 4))
axes = axes.flatten()

for i, item in enumerate(data_list):
    ax = axes[i]
    dfm = item['monthly_mean']
    name = item['name']

    ax.plot(range(1, 13), dfm['Discharge'], color='blue', linewidth=2.5, marker='o', markersize=4)
    ax.set_xticks(range(1, 13))
    ax.set_xticklabels(month_labels, rotation=0)
    ax.set_ylabel('Mean Streamflow (m³/s)')
    ax.set_title(f'({chr(97 + i)}) {name}', pad=10)
    ax.set_ylim(0, 30)
    ax.set_yticks([0, 5, 10, 15, 20, 25, 30])
    ax.grid(True, linestyle='--', alpha=0.7)
    ax.set_xlim(0.8, 12.2)

plt.tight_layout(rect=[0, 0, 1, 0.94])
plt.savefig('monthly_mean_streamflow_four2_basins.png', dpi=300, bbox_inches='tight')
plt.show()
